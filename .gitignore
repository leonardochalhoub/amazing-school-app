# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report
/test-results
/playwright/.cache

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# content pipeline working data (generated, not shipped)
/scripts/content/data/raw/
/scripts/content/data/chunks/
/scripts/content/data/generated/
/scripts/content/data/validated/
/scripts/content/data/manifests/
!/scripts/content/data/.gitkeep

# MCP server config — holds Supabase access token, never commit.
.mcp.json
