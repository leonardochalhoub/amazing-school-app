      "kind": "dialog_pronunciation",
      "title": "Past continuous drill",
      "character": "Detective",
      "pt_summary": "Past continuous — o que estava acontecendo.",
      "turns": [
        {
          "speaker": "ai",
          "text": "What were you doing at eight?",
          "pt": "O que tava fazendo às oito?"
        },
        {
          "speaker": "user",
          "target": "I was having dinner at home.",
          "pt_hint": "WAS + -ing."
        },
        {
          "speaker": "ai",
          "text": "Was anyone with you?",
          "pt": "Tinha alguém com você?"
        },
        {
          "speaker": "user",
          "target": "Yes, my family was eating too.",
          "pt_hint": "WAS EATING."
        },
        {
          "speaker": "ai",
          "text": "What was your brother doing?",
          "pt": "O que seu irmão fazia?"
        },
        {
          "speaker": "user",
          "target": "He was watching TV.",
          "pt_hint": "HE WAS WATCHING."
        },
        {
          "speaker": "ai",
          "text": "Were your neighbors home?",
          "pt": "Os vizinhos estavam?"
        },
        {
          "speaker": "user",
          "target": "Yes, they were playing music.",
          "pt_hint": "THEY WERE."
        },
        {
          "speaker": "ai",
          "text": "Did you hear anything unusual?",
          "pt": "Ouviu algo estranho?"
        },
        {
          "speaker": "user",
          "target": "No, nothing strange was happening.",
          "pt_hint": "WAS HAPPENING."
        },
        {
          "speaker": "ai",
          "text": "OK. Thank you for your time.",
          "pt": "OK. Obrigado."
