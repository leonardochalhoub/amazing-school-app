  "exercises": [
    {
      "id": "pcc-001",
      "type": "multiple_choice",
      "question": "While I ___ dinner, the phone rang.",
      "options": [
        "cooked",
        "was cooking",
        "am cooking",
        "cook"
      ],
      "correct": 1,
      "explanation": "Past continuous for a long action interrupted by a short one.",
      "hint_pt_br": "Passado contínuo para uma ação longa interrompida por outra curta."
    },
    {
      "id": "pcc-002",
      "type": "fill_blank",
      "question": "They ___ (watch) TV when I arrived.",
      "correct": "were watching",
      "explanation": "Were + watching — ongoing past action.",
      "hint_pt_br": "Para 'they', use 'were' + verbo-ing."
    },
    {
      "id": "pcc-003",
      "type": "matching",
      "pairs": [
        [
          "I was reading",
          "Eu estava lendo"
        ],
        [
          "She was driving",
          "Ela estava dirigindo"
        ],
        [
          "We were laughing",
          "Nós estávamos rindo"
        ],
        [
          "They were sleeping",
          "Eles estavam dormindo"
        ]
      ],
      "explanation": "All past-continuous translations.",
      "hint_pt_br": "Todas no passado contínuo."
    },
    {
      "id": "autobal-past-continuous-1-fb",
      "type": "fill_blank",
      "question": "Complete: \"I was ___ dinner at home.\"",
      "correct": "having",
      "explanation": "The full phrase is: \"I was having dinner at home.\"",
      "hint_pt_br": "WAS + -ing."
    },
    {
      "id": "autobal-past-continuous-2-mc",
      "type": "multiple_choice",
      "question": "Pick the best response. (WAS EATING.)",
      "options": [
        "I am not sure.",
        "That is a great idea.",
        "Yes, my family was eating too.",
        "Yes, of course."
      ],
      "correct": 2,
      "explanation": "The correct response is: \"Yes, my family was eating too.\"",
      "hint_pt_br": "WAS EATING."
    }
  ],
